<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">


<xacro:arg name="config_path" default="$(find robot)/config/ros2_control.yaml"/>
<xacro:arg name="mesh_path" default="$(find robot)/meshes"/>
  <!-- ======= Base Link ======= -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.0055181 0.00017252 0.02108" rpy="0 0 0" />
      <mass value="0.72256" />
      <inertia ixx="0.00083515" ixy="-1.4527E-05" ixz="0.0002445"
               iyy="0.00098342" iyz="-2.382E-06" izz="0.00091235" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/base_link.STL" />
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <gravity>1</gravity>
  </gazebo>

  <!-- ======= Left Wheel Link ======= -->
  <link name="LeftWheel_Link">
    <inertial>
      <origin xyz="-0.019789 -0.00021375 -0.00064625" rpy="0 0 0" />
      <mass value="0.041158" />
      <inertia ixx="6.8218E-06" ixy="2.2543E-07" ixz="2.5049E-06"
               iyy="1.1369E-05" iyz="4.004E-08" izz="6.8214E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/LeftWheel_Link.STL" />
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/LeftWheel_Link.STL" />
      </geometry>
    </collision>
  </link>

  <gazebo reference="LeftWheel_Link">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ======= Right Wheel Link ======= -->
  <link name="RightWheel_Link">
    <inertial>
      <origin xyz="-0.019789 0.00021375 -0.00064625" rpy="0 0 0" />
      <mass value="0.041158" />
      <inertia ixx="6.8218E-06" ixy="-2.2543E-07" ixz="2.5049E-06"
               iyy="1.1369E-05" iyz="-4.004E-08" izz="6.8214E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/RightWheel_Link.STL" />
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(arg mesh_path)/RightWheel_Link.STL" />
      </geometry>
    </collision>
  </link>

  <gazebo reference="RightWheel_Link">
    <material>Gazebo/Black</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ======= Joints ======= -->
  <joint name="LeftWheel_Joint" type="continuous">
    <origin xyz="0.00018658 0.115 -0.020" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="LeftWheel_Link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="5.0" />
    <dynamics damping="0.01" friction="0.01" />
  </joint>

  <joint name="RightWheel_Joint" type="continuous">
    <origin xyz="0.00018658 -0.115 -0.020" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="RightWheel_Link" />
    <axis xyz="0 1 0" />
    <limit effort="10.0" velocity="5.0" />
    <dynamics damping="0.01" friction="0.01" />
  </joint>

    <!-- ======= ROS2 Control Hardware Interface ======= -->
  <ros2_control name="robot_hardware" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    
    <!-- 左轮接口 -->
    <joint name="LeftWheel_Joint">
      <command_interface name="velocity">
        <param name="min">-5.0</param>
        <param name="max">5.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- 右轮接口 -->
    <joint name="RightWheel_Joint">
      <command_interface name="velocity">
        <param name="min">-5.0</param>
        <param name="max">5.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <sensor name="imu_sensor">
        <state_interface name="orientation.w"/>
        <state_interface name="orientation.x"/>
        <state_interface name="orientation.y"/>
        <state_interface name="orientation.z"/>
        <state_interface name="angular_velocity.x"/>
        <state_interface name="angular_velocity.y"/>
        <state_interface name="angular_velocity.z"/>
        <state_interface name="linear_acceleration.x"/>
        <state_interface name="linear_acceleration.y"/>
        <state_interface name="linear_acceleration.z"/>
    </sensor>
  </ros2_control>

  <!-- ======= Gazebo ROS2 Control Plugin ======= -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(arg config_path)</parameters>
    </plugin>
  </gazebo>

 <!-- ======= Gazebo IMU 物理传感器（让 ros2_control 直接接管） ======= -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
    </sensor>
  </gazebo>


</robot>

